# =============================================================================
# Trip GPS — Next.js FRONTEND environment template
# -----------------------------------------------------------------------------
# Copy to `.env.local` (gitignored) and restart `npm run dev` after editing.
#
# ARCHITECTURE (Phase 11): the GPS API now lives in a SEPARATE Fastify backend
# (apps/api). In production the Next app only needs the NEXT_PUBLIC_* vars in the
# first block below. The server secrets (Supabase, owner code) belong in the
# BACKEND — set them in apps/api/.env, NOT here. See apps/api/.env.example and
# docs/trip-gps-env-vars.md.
#
# The "SERVER-ONLY" block at the bottom is used ONLY by the same-origin Next
# fallback API routes (app/api/trips/001/*) — i.e. when
# NEXT_PUBLIC_TRIP_GPS_API_BASE is EMPTY (local dev without running the backend).
# Anything WITHOUT the NEXT_PUBLIC_ prefix is SERVER-ONLY and must never be
# exposed to the browser bundle.
# =============================================================================


# =============================================================================
# PUBLIC (sent to the browser) — what the frontend always needs
# =============================================================================

# Base URL of the Fastify backend, e.g. https://api.koonporza.com (no trailing slash).
# Leave EMPTY to call the same-origin Next fallback API routes instead (local dev).
NEXT_PUBLIC_TRIP_GPS_API_BASE=

# 1 = render the GPS UI, 0 = hide it. This only affects what's drawn — it does
# NOT authorize capture/upload (server tokens + the owner code do that).
NEXT_PUBLIC_TRIP_GPS_UI=0

# -----------------------------------------------------------------------------
# Cloudflare Web Analytics beacon token (public, optional)
# How to get it:
#   Cloudflare Dashboard -> Analytics & Logs -> Web Analytics -> add/select your
#   site. Cloudflare shows a JS snippet containing data-cf-beacon='{"token":"..."}'.
#   Copy that 32-char hex token here. Keep "Automatic injection" OFF in the
#   dashboard — the app injects the beacon itself and deliberately never loads it
#   on /trip/NNN/live (the viewer-token URL).
# Leave empty to disable analytics entirely.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CF_BEACON_TOKEN=


# =============================================================================
# SERVER-ONLY — needed ONLY for the local Next-fallback API
# -----------------------------------------------------------------------------
# These power the kept Next route handlers (app/api/trips/001/*) and are read
# ONLY when NEXT_PUBLIC_TRIP_GPS_API_BASE is empty. When you run the Fastify
# backend, leave these unset here and configure them in apps/api/.env instead.
# =============================================================================

# 1 = turn the fallback GPS API on, 0 = off.
# NOTE: isGpsEnabled() only returns true when this is "1" AND both
# TRIP_GPS_SUPABASE_URL and TRIP_GPS_SUPABASE_SERVICE_ROLE_KEY are non-empty.
# (Placeholders pass this gate in dev; the *store* still needs real creds — see
# TRIP_GPS_STORE.) Keep this 0 on any public deploy until tokens/keys are live,
# because /trip/001 itself is public (no password).
TRIP_GPS_ENABLED=0

# -----------------------------------------------------------------------------
# Supabase (server-only) — the production data store
# How to get these:
#   1. Create a free project at https://supabase.com/dashboard (cost = 0฿).
#   2. Run plans/feature-gps/sql/schema.sql in the project's SQL Editor.
#   3. Dashboard -> Project Settings -> "Data API" : copy the Project URL below.
#   4. Dashboard -> Project Settings -> "API Keys" : copy the `service_role`
#      *secret* key (NOT the anon/publishable key) into the next var.
# -----------------------------------------------------------------------------
# Format: https://<project-ref>.supabase.co
TRIP_GPS_SUPABASE_URL=https://example.supabase.co

# The service_role secret key. Full DB access — keep it server-only, never
# NEXT_PUBLIC_*, never commit the real value, never send it to the client.
TRIP_GPS_SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-service-role-key

# -----------------------------------------------------------------------------
# Owner code (server-only) — authorizes starting/stopping a share session
# This is the secret you (the rider) type to begin sharing. Pick ONE option:
#
#   OPTION A — plaintext (simplest): put the code itself in TRIP_GPS_OWNER_CODE.
#     Generate a strong one:   openssl rand -base64 24
#
#   OPTION B — hash only (no plaintext secret in env; recommended for prod):
#     leave TRIP_GPS_OWNER_CODE empty and set TRIP_GPS_OWNER_CODE_HASH to the
#     hex SHA-256 of your code. The server hashes input the same way and compares
#     in constant time. The code is .trim()'d first, so hash WITHOUT a trailing
#     newline:
#       printf %s 'your-owner-code' | shasum -a 256 | awk '{print $1}'
#
# Precedence: TRIP_GPS_OWNER_CODE_HASH (or _SHA256) wins when set; otherwise the
# plaintext TRIP_GPS_OWNER_CODE is used. Set EITHER the plaintext OR a hash.
# -----------------------------------------------------------------------------
# Option A: the owner code in plaintext.
TRIP_GPS_OWNER_CODE=replace-with-owner-code

# Option B: hex SHA-256 of the owner code (takes precedence over the plaintext).
TRIP_GPS_OWNER_CODE_HASH=replace-with-sha256-owner-code-hash

# Alias for the hash above (same meaning; either name works).
TRIP_GPS_OWNER_CODE_SHA256=replace-with-sha256-owner-code-hash

# -----------------------------------------------------------------------------
# Store selector (fallback API)
# -----------------------------------------------------------------------------
# auto     = Supabase in production with real env, in-memory mock otherwise (dev).
# supabase = force the Supabase store (needs the two Supabase vars above).
# mock / memory = force the in-memory store (data is lost on restart; dev/testing).
TRIP_GPS_STORE=auto
