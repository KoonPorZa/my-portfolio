# =============================================================================
# apps/web — Next.js frontend env. Copy to apps/web/.env.local (gitignored).
# NEXT_PUBLIC_* are inlined into the browser bundle at build time; everything
# else is SERVER-ONLY (never prefix a secret with NEXT_PUBLIC_).
# Where each value comes from: docs/env-doc.md
# =============================================================================

# --- Public: frontend (build-time, sent to the browser) ----------------------

# Fastify backend base URL, e.g. https://api.koonporza.com (no trailing slash).
# Empty = use the same-origin Next fallback API (local dev, no backend running).
NEXT_PUBLIC_TRIP_GPS_API_BASE=

# Show the GPS UI: 1 = show, 0 = hide. UI flag only, not authorization.
NEXT_PUBLIC_TRIP_GPS_UI=0

# Cloudflare Web Analytics beacon token (optional). Empty = analytics off.
NEXT_PUBLIC_CF_BEACON_TOKEN=

# Supabase realtime for the live-location banner on /trip/001. The browser
# subscribes to the `trip_location_latest` table to show sharing in realtime.
# Use the PUBLIC "anon" key here (safe in the bundle) — NEVER the service_role
# key. Both are read at build time (NEXT_PUBLIC_*).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Optional: Google motorcycle map (Phase 17, billed, OFF by default) ------
# Set ENABLED=1 AND supply a browser key to activate the Google Maps JS mode.
# The browser key MUST be restricted to HTTP-referrer + a low per-key quota in
# the Google Cloud console (see DEPLOY.md). It is a SEPARATE key from the
# Routes API server key (GOOGLE_MAPS_ROUTES_API_KEY in apps/api).
NEXT_PUBLIC_TRIP_GOOGLE_MAP_ENABLED=0
NEXT_PUBLIC_GOOGLE_MAPS_BROWSER_KEY=

# --- Server-only: social stats (optional, used by the portfolio home) --------

# GitHub token — raises the rate limit when fetching GitHub stats.
GITHUB_TOKEN=

# YouTube Data API key — channel stats. Empty = static fallback tile.
YOUTUBE_API_KEY=

# --- Server-only: Next GPS fallback API --------------------------------------
# Read ONLY when NEXT_PUBLIC_TRIP_GPS_API_BASE is empty. When the Fastify
# backend is used, leave these unset here and configure apps/api/.env instead.

# Turn the fallback GPS API on (1) / off (0). Keep 0 on public deploys.
TRIP_GPS_ENABLED=0

# Store backend: auto | supabase | mock | memory.
TRIP_GPS_STORE=auto

# Supabase project URL: https://<project-ref>.supabase.co
TRIP_GPS_SUPABASE_URL=

# Supabase service_role secret key (full DB access; server-only).
TRIP_GPS_SUPABASE_SERVICE_ROLE_KEY=

# Owner code (plaintext) that authorizes start/stop sharing.
TRIP_GPS_OWNER_CODE=
