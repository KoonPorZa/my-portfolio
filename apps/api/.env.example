# =============================================================================
# Trip GPS — Fastify BACKEND environment template (apps/api)
# -----------------------------------------------------------------------------
# Copy to `apps/api/.env` for local runs, or set the same variables in your
# backend host (Railway / Render / Fly.io). THIS service owns the server secrets
# (Supabase service-role key + owner code) — the Next frontend must never carry
# them. None of these are NEXT_PUBLIC_; never expose them to the browser.
# See docs/trip-gps-env-vars.md for the full reference.
# =============================================================================

# Runtime mode. Use `production` on a real host (enables fail-fast checks below).
NODE_ENV=development

# Port the backend listens on. Most hosts inject PORT automatically — leave as is
# unless running several services locally.
PORT=3000

# -----------------------------------------------------------------------------
# CORS — which browser origins may call this API
# -----------------------------------------------------------------------------
# Comma-separated, exact origins (scheme + host + optional port), no trailing slash.
# MUST include every site that serves the Next frontend, e.g. the production domain
# and (for local dev) http://localhost:3000. An origin not in this list gets no
# access-control-allow-origin header, so the browser blocks the response.
CORS_ORIGINS=http://localhost:3000,https://koonporza.com,https://www.koonporza.com

# Master switch for Trip GPS server behavior (1 = on, 0 = off).
TRIP_GPS_ENABLED=1

# -----------------------------------------------------------------------------
# Store selector
# -----------------------------------------------------------------------------
# auto     = Supabase when NODE_ENV=production AND real Supabase env is set,
#            in-memory otherwise.
# supabase = force Supabase; FAILS FAST at startup if the creds below are
#            missing/placeholder.
# mock / memory = in-memory store (data lost on restart) — good for local dev/tests.
TRIP_GPS_STORE=memory

# -----------------------------------------------------------------------------
# Supabase (the production data store)
# How to get these:
#   1. Create a free project at https://supabase.com/dashboard (cost = 0฿).
#   2. Run plans/feature-gps/sql/schema.sql in the project's SQL Editor.
#   3. Dashboard -> Project Settings -> "Data API"  : copy the Project URL.
#   4. Dashboard -> Project Settings -> "API Keys"  : copy the `service_role`
#      *secret* key (NOT the anon/publishable key).
# Both are required when TRIP_GPS_STORE=supabase (or auto in production).
# -----------------------------------------------------------------------------
# Format: https://<project-ref>.supabase.co
TRIP_GPS_SUPABASE_URL=

# service_role secret key — full DB access. Server-only; never NEXT_PUBLIC_.
TRIP_GPS_SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Owner code — authorizes starting/stopping a share session
# Pick ONE option:
#
#   OPTION A — hash only (recommended): leave TRIP_GPS_OWNER_CODE unset and set
#     TRIP_GPS_OWNER_CODE_HASH to the hex SHA-256 of your code, so no plaintext
#     secret lives in env. Generate:
#       openssl rand -base64 24                                  # the code
#       printf %s 'your-owner-code' | shasum -a 256 | awk '{print $1}'   # the hash
#     (the code is .trim()'d before hashing, so hash WITHOUT a trailing newline)
#
#   OPTION B — plaintext (simplest, e.g. local dev): set TRIP_GPS_OWNER_CODE to
#     the code itself and leave the hash unset.
#
# Precedence: TRIP_GPS_OWNER_CODE_HASH (or TRIP_GPS_OWNER_CODE_SHA256) wins when
# set; otherwise the plaintext TRIP_GPS_OWNER_CODE is used.
# -----------------------------------------------------------------------------
# Option A: hex SHA-256 of the owner code (takes precedence).
TRIP_GPS_OWNER_CODE_HASH=

# Alias for the hash above (same meaning; either name works).
TRIP_GPS_OWNER_CODE_SHA256=

# Option B: the owner code in plaintext (used only if no hash is set).
TRIP_GPS_OWNER_CODE=
