# =============================================================================
# apps/api — Fastify backend env. Copy to apps/api/.env, or set on your host
# (Railway / Render / Fly.io). This service owns the server secrets; none are
# NEXT_PUBLIC_. Where each value comes from: docs/env-doc.md
# =============================================================================

# --- Server runtime ----------------------------------------------------------

# development | production. Use production on a real host (enables fail-fast).
NODE_ENV=development

# Listen port. Most hosts inject PORT automatically.
PORT=3000

# --- CORS: browser origins allowed to call this API --------------------------

# Comma-separated exact origins (scheme+host+port, no trailing slash). Include
# every frontend origin, e.g. the production site + local dev.
CORS_ORIGINS=http://localhost:3000,https://koonporza.com,https://www.koonporza.com

# --- Trip GPS ----------------------------------------------------------------

# Master switch: 1 = on, 0 = off.
TRIP_GPS_ENABLED=1

# Store backend: auto | supabase | mock | memory. supabase fails fast if the
# Supabase creds below are missing.
TRIP_GPS_STORE=memory

# --- Supabase: data store (required when TRIP_GPS_STORE=supabase, or auto+prod)

# https://<project-ref>.supabase.co
TRIP_GPS_SUPABASE_URL=

# service_role secret key — full DB access; server-only.
TRIP_GPS_SUPABASE_SERVICE_ROLE_KEY=

# --- Owner code: authorizes start/stop sharing (plaintext) -------------------

TRIP_GPS_OWNER_CODE=
