# Enables server-side GPS checks when set to 1; keep 0 for local mock-only dev.
TRIP_GPS_ENABLED=0

# Server-only secret: Supabase project URL; this placeholder keeps auto mode on the mock.
TRIP_GPS_SUPABASE_URL=https://example.supabase.co

# Server-only secret: Supabase service-role key; never expose this as NEXT_PUBLIC_*.
TRIP_GPS_SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-service-role-key

# Server-only secret: owner code for starting/stopping a GPS session.
TRIP_GPS_OWNER_CODE=replace-with-owner-code

# Server-only secret alternative: SHA-256 hash of the owner code; takes precedence when set.
TRIP_GPS_OWNER_CODE_HASH=replace-with-sha256-owner-code-hash

# Server-only secret alias: SHA-256 hash of the owner code; supported by Phase 7.
TRIP_GPS_OWNER_CODE_SHA256=replace-with-sha256-owner-code-hash

# Public UI flag: set to 1 to show the GPS UI; it does not authorize uploads.
NEXT_PUBLIC_TRIP_GPS_UI=0

# Store selector: auto uses Supabase only in production with real env; use supabase, mock, or memory to force a provider.
TRIP_GPS_STORE=auto
